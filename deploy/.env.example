QC_SUITE_LOCAL_ONLY=1
QC_SUITE_HOST=127.0.0.1
QC_SUITE_PORT=8100
QC_SUITE_DEBUG=0
QC_SUITE_SECRET_KEY=CHANGE_ME_IN_PRODUCTION
QC_SUITE_ACCESS_TOKEN_TTL_SECONDS=86400
QC_SUITE_DATA_ROOT=./data
QC_SUITE_SERVER_URL=local://embedded
QC_SUITE_UPLOAD_INTERVAL_MS=500

QC_SUITE_STICKER_INFERENCE_MODE=ultralytics
QC_SUITE_DEFAULT_STICKER_MODEL_PATH=
QC_SUITE_DEFAULT_STICKER_MODEL_META_PATH=
QC_SUITE_DEVICE=auto
QC_SUITE_CUDA_DEVICE_ID=0

QC_SUITE_TRAINING_ENGINE_MODE=real
QC_SUITE_TRAINING_TIMEOUT_MINUTES=720
QC_SUITE_TRAINING_DEFAULT_EPOCHS=200
QC_SUITE_TRAINING_DEFAULT_IMGSZ=640
QC_SUITE_TRAINING_DEFAULT_BATCH=16
QC_SUITE_TRAINING_DEFAULT_PATIENCE=20
QC_SUITE_TRAINING_WEIGHTS_DOWNLOAD_ALLOWED=1
QC_SUITE_GPU_FAIL_FAST=1
QC_SUITE_PUSH_WORKER_INTERVAL_SECONDS=30
QC_SUITE_PUSH_WORKER_MAX_RETRY=5

# PLC / remote-IO clamp control.
#
# Transport selector:
#   tcp = Modbus TCP gateway / Ethernet remote I/O / TCP slave-server simulator.
#   rtu = serial Modbus RTU relay module over COM/tty.
#
# SIMULATOR vs REAL HARDWARE:
#   QModBus / ModbusPal / diagslave are TCP slave/server simulators and are useful
#   when QC_SUITE_PLC_TRANSPORT=tcp.
#   QModMaster is a master/client tool — it cannot act as the slave/server that the
#   backend connects to.
#
# HARDWARE FAIL-SAFE WARNING:
# The software safe-release (atexit + plc_worker.stop) is a best-effort layer only.
# It does NOT protect against power loss, OS crash, hard kill, or PC hang.
# The clamp circuit must have a hardware-level fail-safe as the primary protection:
# spring-return valve, PLC watchdog, or a normally-open relay that opens on
# communication loss. Treat software safe-release as a supplementary convenience,
# not a safety guarantee.
#
# Set QC_SUITE_PLC_ENABLED=1 only when the PLC or gateway is reachable.
# Keep QC_SUITE_PLC_DRY_RUN=1 during initial setup or if no hardware is connected.
QC_SUITE_PLC_ENABLED=0
QC_SUITE_PLC_DRY_RUN=1
QC_SUITE_PLC_TRANSPORT=tcp

# TCP settings (used when QC_SUITE_PLC_TRANSPORT=tcp).
QC_SUITE_PLC_HOST=127.0.0.1
QC_SUITE_PLC_PORT=5020

# RTU settings (used when QC_SUITE_PLC_TRANSPORT=rtu).
# Example relay module setup: slave id 255, coil 0/1, COM3 on Windows.
QC_SUITE_PLC_SERIAL_PORT=COM3
QC_SUITE_PLC_SERIAL_BAUDRATE=9600
QC_SUITE_PLC_SERIAL_PARITY=N
QC_SUITE_PLC_SERIAL_BYTESIZE=8
QC_SUITE_PLC_SERIAL_STOPBITS=1

QC_SUITE_PLC_TIMEOUT_MS=1000
QC_SUITE_PLC_CLAMP_HOLD_MS=2000

# Modbus TCP address map — lock these values from the remote I/O datasheet.
# Example layout (placeholder — replace with actual datasheet values):
#   Coil 0  (Q0): clamp output (hold=1 / release=0)
#   DI 4    (I4): clamp-engaged feedback sensor (separate physical input)
#
# ADDRESSING: check the remote I/O manual for 0-based vs 1-based addressing.
#   Zero-based  (most remote I/O modules): address 0 maps to coil Q0.
#   One-based   (some PLCs): address 1 maps to coil Q1; set ZERO_BASED=0.
QC_SUITE_PLC_MODBUS_UNIT_ID=1
QC_SUITE_PLC_MODBUS_COMMAND_MODE=coil
QC_SUITE_PLC_MODBUS_HOLD_ADDRESS=0
QC_SUITE_PLC_MODBUS_RELEASE_ADDRESS=0
QC_SUITE_PLC_MODBUS_HOLD_VALUE=1
QC_SUITE_PLC_MODBUS_RELEASE_VALUE=0
QC_SUITE_PLC_MODBUS_ZERO_BASED_ADDRESSING=1

# Readback: verify that the clamp actually moved, not just that the output coil changed.
# Point readback_address at a SEPARATE discrete input (DI) that reflects physical state —
# for example a limit switch or sensor wired to I4 on the remote I/O.
# Use readback_mode=discrete_input (FC02) for DI feedback, coil for output self-check,
# or holding_register if the remote I/O maps feedback to a register.
# Set READBACK_ENABLED=0 when no physical feedback sensor is available yet.
QC_SUITE_PLC_MODBUS_READBACK_ENABLED=0
QC_SUITE_PLC_MODBUS_READBACK_MODE=discrete_input
QC_SUITE_PLC_MODBUS_READBACK_ADDRESS=4
QC_SUITE_PLC_MODBUS_READBACK_EXPECTED_HOLD_VALUE=1
QC_SUITE_PLC_MODBUS_READBACK_EXPECTED_RELEASE_VALUE=0

QC_SUITE_PART_READY_SETTLE_MS=1500
QC_SUITE_GEOMETRIC_AUGMENT_ENABLED=0

# Legacy remote-streaming knobs retained for compatibility with split deployments.
# Local-only desktop mode ignores these values.
QC_SUITE_STREAM_PORT=8101
QC_SUITE_STREAM_HOST=
QC_SUITE_STREAM_URL=

QC_SUITE_ACCESS_LOGS_ENABLED=0
QC_SUITE_WERKZEUG_REQUEST_LOGS_ENABLED=0

# Mode default desktop lokal. Ubah ke 0 hanya jika ingin split deployment atau backend terpisah.
QC_SUITE_DATABASE_BACKEND=local
# Legacy compatibility toggle untuk SQL Server. Biarkan 0 untuk desktop-only / PostgreSQL.
QC_SUITE_SQL_ENABLED=0

POSTGRESQL_HOST=
POSTGRESQL_PORT=5432
POSTGRESQL_DATABASE=
POSTGRESQL_USERNAME=
POSTGRESQL_PASSWORD=
POSTGRESQL_SCHEMA=public
POSTGRESQL_SSLMODE=prefer

MSSQL_SERVER=
MSSQL_DATABASE=
MSSQL_USERNAME=
MSSQL_PASSWORD=
MSSQL_DRIVER=ODBC Driver 18 for SQL Server

#
# Penjelasan singkat setiap variabel dan value yang bisa digunakan:
#
# QC_SUITE_LOCAL_ONLY
# - Fungsi: mode desktop lokal; backend berjalan embedded di dalam proses aplikasi.
# - Value: 1 = local-only (default), 0 = remote client ke backend server terpisah.
#
# QC_SUITE_HOST
# - Fungsi: alamat bind server.
# - Value: 127.0.0.1 untuk desktop-only; 0.0.0.0 hanya jika menjalankan backend terpisah.
#
# QC_SUITE_PORT
# - Fungsi: port server.
# - Value: angka port valid, contoh 8100.
#
# QC_SUITE_DEBUG
# - Fungsi: mode debug.
# - Value: 0 atau 1.
#
# QC_SUITE_SECRET_KEY
# - Fungsi: secret untuk session/signing.
# - Value: string bebas, sebaiknya random dan panjang untuk production.
#
# QC_SUITE_ACCESS_TOKEN_TTL_SECONDS
# - Fungsi: masa aktif access token dalam detik.
# - Value: angka, minimum 60.
#
# QC_SUITE_DATA_ROOT
# - Fungsi: folder data utama.
# - Value: path absolut atau relatif; kosong berarti pakai default folder data repo.
#
# QC_SUITE_SERVER_URL
# - Fungsi: URL backend yang dipakai client.
# - Value: local://embedded untuk desktop-only; http://IP:PORT hanya untuk split deployment.
#
# QC_SUITE_UPLOAD_INTERVAL_MS
# - Fungsi: interval upload dalam milidetik.
# - Value: angka, contoh 500.
#
# QC_SUITE_STICKER_INFERENCE_MODE
# - Fungsi: mode runtime inference sticker.
# - Value: auto, ultralytics, classic.
#
# QC_SUITE_DEFAULT_STICKER_MODEL_PATH
# - Fungsi: path file model default.
# - Value: path absolut atau relatif; boleh kosong untuk pakai default bawaan.
#
# QC_SUITE_DEFAULT_STICKER_MODEL_META_PATH
# - Fungsi: path metadata model default.
# - Value: path absolut atau relatif; boleh kosong untuk pakai default bawaan.
#
# QC_SUITE_DEVICE
# - Fungsi: mode device runtime.
# - Value: auto, gpu, cpu.
#
# QC_SUITE_CUDA_DEVICE_ID
# - Fungsi: index GPU yang dipakai.
# - Value: angka 0 atau lebih.
#
# QC_SUITE_TRAINING_ENGINE_MODE
# - Fungsi: mode engine training.
# - Value: real, simulated.
#
# QC_SUITE_TRAINING_TIMEOUT_MINUTES
# - Fungsi: timeout training dalam menit.
# - Value: angka, minimum 1.
#
# QC_SUITE_TRAINING_DEFAULT_EPOCHS
# - Fungsi: default epoch training.
# - Value: angka, minimum 1.
#
# QC_SUITE_TRAINING_DEFAULT_IMGSZ
# - Fungsi: ukuran input training.
# - Value: angka, minimum 64.
#
# QC_SUITE_TRAINING_DEFAULT_BATCH
# - Fungsi: ukuran batch training.
# - Value: angka, minimum 1.
#
# QC_SUITE_TRAINING_DEFAULT_PATIENCE
# - Fungsi: patience untuk early stopping.
# - Value: angka, minimum 1.
#
# QC_SUITE_TRAINING_WEIGHTS_DOWNLOAD_ALLOWED
# - Fungsi: izin auto-download weights.
# - Value: 0 = tidak boleh download, 1 = boleh download.
#
# QC_SUITE_GPU_FAIL_FAST
# - Fungsi: kebijakan gagal cepat saat GPU tidak tersedia.
# - Value: 1 = fail fast, 0 = fallback ke CPU.
#
# QC_SUITE_PUSH_WORKER_INTERVAL_SECONDS
# - Fungsi: interval worker push.
# - Value: angka, minimum 5.
#
# QC_SUITE_PUSH_WORKER_MAX_RETRY
# - Fungsi: batas retry worker push.
# - Value: angka, minimum 1.

# QC_SUITE_PLC_ENABLED
# - Fungsi: mengaktifkan worker PLC / remote-IO clamp control.
# - Value: 0 = off (default), 1 = aktif.
#
# QC_SUITE_PLC_DRY_RUN
# - Fungsi: mode simulasi yang hanya log command tanpa membuka socket hardware.
# - Value: 1 = dry-run (default aman), 0 = kirim ke PLC/gateway.
#
# QC_SUITE_PLC_HOST
# - Fungsi: host atau IP PLC/gateway remote IO.
# - Value: string host/IP, contoh 127.0.0.1 atau alamat PLC sebenarnya.
#
# QC_SUITE_PLC_PORT
# - Fungsi: port TCP PLC/gateway.
# - Value: angka port valid, contoh 5020.
#
# QC_SUITE_PLC_TIMEOUT_MS
# - Fungsi: timeout connect/send socket PLC.
# - Value: angka dalam milidetik, minimum 100.
#
# QC_SUITE_PLC_CLAMP_HOLD_MS
# - Fungsi: lama clamp ditahan sebelum release otomatis.
# - Value: angka dalam milidetik, minimum 0.
#
# QC_SUITE_PLC_MODBUS_READBACK_MODE
# - Fungsi: cara membaca status balik setelah command dikirim.
# - Value: discrete_input = baca DI fisik (FC02, rekomendasi untuk sensor feedback),
#           coil = baca coil output yang sama (hanya verifikasi register, bukan mekanik),
#           holding_register = baca register,
#           none = tidak ada readback.
# - Catatan: gunakan discrete_input dengan READBACK_ADDRESS yang berbeda dari
#   HOLD/RELEASE_ADDRESS supaya feedback mencerminkan kondisi mekanik nyata,
#   bukan hanya echo register output.
#
# QC_SUITE_PLC_MODBUS_READBACK_ADDRESS
# - Fungsi: alamat point feedback (DI, coil, atau register) di remote I/O.
# - Value: angka, sesuaikan dengan datasheet hardware.
#   Contoh: coil Q0 = address 0 untuk output, DI I4 = address 4 untuk feedback sensor.
#
# QC_SUITE_PART_READY_SETTLE_MS
# - Fungsi: delay settle default.
# - Value: angka, minimum 0; 0 berarti nonaktif.
#
# QC_SUITE_GEOMETRIC_AUGMENT_ENABLED
# - Fungsi: fitur augmentasi geometrik.
# - Value: 0 = nonaktif, 1 = aktif.
#
# QC_SUITE_STREAM_PORT
# - Fungsi: port WebSocket streaming server untuk kompatibilitas deployment lama.
# - Value: angka port valid, contoh 8101. Local-only desktop tidak memakainya.
#
# QC_SUITE_STREAM_HOST
# - Fungsi: bind address WebSocket streaming server untuk mode split deployment lama.
# - Value: kosong = ikut QC_SUITE_HOST; atau isi 0.0.0.0 untuk bind semua interface.
#
# QC_SUITE_STREAM_URL
# - Fungsi: URL WebSocket streaming yang dipakai client split-mode lama.
# - Value: format ws://IP:PORT, kosong berarti nonaktif.
#
# QC_SUITE_ACCESS_LOGS_ENABLED
# - Fungsi: aktif/nonaktif access log.
# - Value: 0 = mati, selain 0 = aktif.
#
# QC_SUITE_WERKZEUG_REQUEST_LOGS_ENABLED
# - Fungsi: aktif/nonaktif request log Werkzeug.
# - Value: 0 = mati, selain 0 = aktif.

# QC_SUITE_DATABASE_BACKEND
# - Fungsi: memilih backend persistence relasional.
# - Value: local, sqlserver, postgresql. Default desktop-only tetap local.
# - Catatan: isi POSTGRESQL_* lalu ubah value ini ke postgresql saat ingin migrasi penuh.
# - Rekomendasi: gunakan postgresql untuk deployment baru.

# QC_SUITE_SQL_ENABLED
# - Fungsi: toggle kompatibilitas SQL Server untuk deployment lama.
# - Value: 0 = off (desktop-only/PostgreSQL default), 1 = on jika MSSQL_* diisi.

# POSTGRESQL_HOST
# - Fungsi: host atau IP PostgreSQL.
# - Value: string host/IP.
#
# POSTGRESQL_PORT
# - Fungsi: port PostgreSQL.
# - Value: angka port valid, default 5432.
#
# POSTGRESQL_DATABASE
# - Fungsi: nama database PostgreSQL.
# - Value: string nama database.
#
# POSTGRESQL_USERNAME
# - Fungsi: username PostgreSQL.
# - Value: string username.
#
# POSTGRESQL_PASSWORD
# - Fungsi: password PostgreSQL.
# - Value: string password.
#
# POSTGRESQL_SCHEMA
# - Fungsi: schema PostgreSQL yang dipakai repository.
# - Value: nama schema, default public.
#
# POSTGRESQL_SSLMODE
# - Fungsi: mode SSL connection PostgreSQL.
# - Value: disable, allow, prefer, require, verify-ca, verify-full.
#
# MSSQL_SERVER
# - Fungsi: host atau IP SQL Server.
# - Value: string host/IP.
#
# MSSQL_DATABASE
# - Fungsi: nama database.
# - Value: string nama database.
#
# MSSQL_USERNAME
# - Fungsi: username database.
# - Value: string username.
#
# MSSQL_PASSWORD
# - Fungsi: password database.
# - Value: string password.
#
# MSSQL_DRIVER
# - Fungsi: nama driver ODBC untuk SQL Server.
# - Value: nama driver yang terpasang, misalnya ODBC Driver 17 for SQL Server atau ODBC Driver 18 for SQL Server.