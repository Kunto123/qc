#
# Penjelasan singkat setiap variabel dan value yang bisa digunakan:
#
# QC_SUITE_HOST
# - Fungsi: alamat bind server.
# - Value: 127.0.0.1 untuk lokal, 0.0.0.0 agar bisa diakses dari device lain.
#
# QC_SUITE_PORT
# - Fungsi: port server.
# - Value: angka port valid, contoh 8100.
#
# QC_SUITE_DEBUG
# - Fungsi: mode debug.
# - Value: 0 atau 1.
#
# QC_SUITE_SECRET_KEY
# - Fungsi: secret untuk session/signing.
# - Value: string bebas, sebaiknya random dan panjang untuk production.
#
# QC_SUITE_ACCESS_TOKEN_TTL_SECONDS
# - Fungsi: masa aktif access token dalam detik.
# - Value: angka, minimum 60.
#
# QC_SUITE_DATA_ROOT
# - Fungsi: folder data utama.
# - Value: path absolut atau relatif; kosong berarti pakai default folder data repo.
#
# QC_SUITE_SERVER_URL
# - Fungsi: URL backend yang dipakai client.
# - Value: format http://IP:PORT, contoh http://127.0.0.1:8100.
#
# QC_SUITE_UPLOAD_INTERVAL_MS
# - Fungsi: interval upload dalam milidetik.
# - Value: angka, contoh 500.
#
# QC_SUITE_STICKER_INFERENCE_MODE
# - Fungsi: mode runtime inference sticker.
# - Value: auto, ultralytics, classic.
#
# QC_SUITE_DEFAULT_STICKER_MODEL_PATH
# - Fungsi: path file model default.
# - Value: path absolut atau relatif; boleh kosong untuk pakai default bawaan.
#
# QC_SUITE_DEFAULT_STICKER_MODEL_META_PATH
# - Fungsi: path metadata model default.
# - Value: path absolut atau relatif; boleh kosong untuk pakai default bawaan.
#
# QC_SUITE_DEVICE
# - Fungsi: mode device runtime.
# - Value: auto, gpu, cpu.
#
# QC_SUITE_CUDA_DEVICE_ID
# - Fungsi: index GPU yang dipakai.
# - Value: angka 0 atau lebih.
#
# QC_SUITE_TRAINING_ENGINE_MODE
# - Fungsi: mode engine training.
# - Value: real, simulated.
#
# QC_SUITE_TRAINING_TIMEOUT_MINUTES
# - Fungsi: timeout training dalam menit.
# - Value: angka, minimum 1.
#
# QC_SUITE_TRAINING_DEFAULT_EPOCHS
# - Fungsi: default epoch training.
# - Value: angka, minimum 1.
#
# QC_SUITE_TRAINING_DEFAULT_IMGSZ
# - Fungsi: ukuran input training.
# - Value: angka, minimum 64.
#
# QC_SUITE_TRAINING_DEFAULT_BATCH
# - Fungsi: ukuran batch training.
# - Value: angka, minimum 1.
#
# QC_SUITE_TRAINING_DEFAULT_PATIENCE
# - Fungsi: patience untuk early stopping.
# - Value: angka, minimum 1.
#
# QC_SUITE_TRAINING_WEIGHTS_DOWNLOAD_ALLOWED
# - Fungsi: izin auto-download weights.
# - Value: 0 = tidak boleh download, 1 = boleh download.
#
# QC_SUITE_GPU_FAIL_FAST
# - Fungsi: kebijakan gagal cepat saat GPU tidak tersedia.
# - Value: 1 = fail fast, 0 = fallback ke CPU.
#
# QC_SUITE_PUSH_WORKER_INTERVAL_SECONDS
# - Fungsi: interval worker push.
# - Value: angka, minimum 5.
#
# QC_SUITE_PUSH_WORKER_MAX_RETRY
# - Fungsi: batas retry worker push.
# - Value: angka, minimum 1.
#
# QC_SUITE_PART_READY_SETTLE_MS
# - Fungsi: delay settle default.
# - Value: angka, minimum 0; 0 berarti nonaktif.
#
# QC_SUITE_GEOMETRIC_AUGMENT_ENABLED
# - Fungsi: fitur augmentasi geometrik.
# - Value: 0 = nonaktif, 1 = aktif.
#
# QC_SUITE_STREAM_PORT
# - Fungsi: port WebSocket streaming server (sidecar, terpisah dari HTTP).
# - Value: angka port valid, contoh 8101. Default 8101.
#
# QC_SUITE_STREAM_HOST
# - Fungsi: bind address WebSocket streaming server.
# - Value: kosong = ikut QC_SUITE_HOST; atau isi 0.0.0.0 untuk bind semua interface.
#
# QC_SUITE_STREAM_URL
# - Fungsi: URL WebSocket streaming yang dipakai client untuk connect.
# - Value: format ws://IP:PORT, contoh ws://127.0.0.1:8101.
#
# QC_SUITE_ACCESS_LOGS_ENABLED
# - Fungsi: aktif/nonaktif access log.
# - Value: 0 = mati, selain 0 = aktif.
#
# QC_SUITE_WERKZEUG_REQUEST_LOGS_ENABLED
# - Fungsi: aktif/nonaktif request log Werkzeug.
# - Value: 0 = mati, selain 0 = aktif.
#
# MSSQL_SERVER
# - Fungsi: host atau IP SQL Server.
# - Value: string host/IP.
#
# MSSQL_DATABASE
# - Fungsi: nama database.
# - Value: string nama database.
#
# MSSQL_USERNAME
# - Fungsi: username database.
# - Value: string username.
#
# MSSQL_PASSWORD
# - Fungsi: password database.
# - Value: string password.
#
# MSSQL_DRIVER
# - Fungsi: nama driver ODBC untuk SQL Server.
# - Value: nama driver yang terpasang, misalnya ODBC Driver 17 for SQL Server atau ODBC Driver 18 for SQL Server.