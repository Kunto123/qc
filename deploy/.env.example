QC_SUITE_HOST=127.0.0.1
QC_SUITE_PORT=8100
QC_SUITE_DEBUG=0
QC_SUITE_SECRET_KEY=qc-suite-dev-secret
QC_SUITE_ACCESS_TOKEN_TTL_SECONDS=86400
QC_SUITE_DATA_ROOT=
QC_SUITE_SERVER_URL=http://127.0.0.1:8100
QC_SUITE_STICKER_INFERENCE_MODE=auto
QC_SUITE_DEFAULT_STICKER_MODEL_PATH=
QC_SUITE_DEFAULT_STICKER_MODEL_META_PATH=
QC_SUITE_UPLOAD_INTERVAL_MS=500
# Settle-time debounce system-wide default (milliseconds).
# Templates that do not set part_ready_settle_ms explicitly will use this value.
# 0 = disabled (legacy behaviour). Recommended for production: 1500.
QC_SUITE_PART_READY_SETTLE_MS=0

# --- Training weights resolution policy ---
# QC_SUITE_TRAINING_WEIGHTS_DOWNLOAD_ALLOWED=1 (default): the training worker will attempt to
# auto-download base model weights from Ultralytics Hub when the file is not in MODELS_DIR.
# Suitable for dev environments with internet access.
# Set to 0 for offline-strict / production: the job will be rejected at the API if weights are
# not already cached locally, giving an actionable error instead of a silent download attempt.
# Runbook: pre-populate MODELS_DIR by running:
#   python -c "from ultralytics import YOLO; [YOLO(m) for m in ['yolov11n.pt','yolov11s.pt','yolov11m.pt','yolov11l.pt','yolov11x.pt','yolov5n.pt','yolov5s.pt','yolov5m.pt']]"
# Then copy the cached .pt files (usually ~/.cache/ultralytics/) to MODELS_DIR.
QC_SUITE_TRAINING_WEIGHTS_DOWNLOAD_ALLOWED=1

# --- Geometric augmentation feature flag ---
# QC_SUITE_GEOMETRIC_AUGMENT_ENABLED=0 (default): geometric transforms (flip_h, flip_v, rotate)
# are rejected when including augment jobs in a version snapshot.
# Set to 1 to enable: bounding-box annotations will be transformed by the label geometry engine.
QC_SUITE_GEOMETRIC_AUGMENT_ENABLED=0

# --- Logging toggles (default ON = backward-compatible) ---
# Set QC_SUITE_ACCESS_LOGS_ENABLED=0 to suppress 2xx/3xx request lines while
# keeping >= 400 errors visible.  Useful during training analysis to reduce noise.
QC_SUITE_ACCESS_LOGS_ENABLED=1
# Set QC_SUITE_WERKZEUG_REQUEST_LOGS_ENABLED=0 to silence werkzeug's own
# per-request lines (e.g. "GET /train/jobs HTTP/1.1" 200).
QC_SUITE_WERKZEUG_REQUEST_LOGS_ENABLED=1

# --- GPU policy ---
# QC_SUITE_GPU_FAIL_FAST=1 (default): a training job requesting device=gpu will
# fail immediately with a clear error if CUDA is unavailable, instead of silently
# falling back to CPU. Set to 0 to restore the legacy silent-fallback behavior.
QC_SUITE_GPU_FAIL_FAST=1

MSSQL_SERVER=
MSSQL_DATABASE=
MSSQL_USERNAME=
MSSQL_PASSWORD=
MSSQL_DRIVER=ODBC Driver 17 for SQL Server

