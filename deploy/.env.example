# QC Suite local-only environment
# Copy this file to .env for a single-PC desktop/operator setup.

# Core local runtime
QC_SUITE_LOCAL_ONLY=1
QC_SUITE_SERVER_URL=local://embedded
QC_SUITE_DATABASE_BACKEND=local
QC_SUITE_SECRET_KEY=CHANGE_ME_LOCAL_SECRET
QC_SUITE_ACCESS_TOKEN_TTL_SECONDS=86400
QC_SUITE_DATA_ROOT=./data
QC_SUITE_ACCESS_LOGS_ENABLED=0
QC_SUITE_WERKZEUG_REQUEST_LOGS_ENABLED=0

# Camera and operator preview
QC_SUITE_UPLOAD_INTERVAL_MS=150
QC_SUITE_OPERATOR_PREVIEW_FPS=20
QC_SUITE_CAMERA_WIDTH=0
QC_SUITE_CAMERA_HEIGHT=0
QC_SUITE_CAMERA_FPS=0

# Sticker model runtime
QC_SUITE_STICKER_INFERENCE_MODE=ultralytics
QC_SUITE_DEFAULT_STICKER_MODEL_PATH=
QC_SUITE_DEFAULT_STICKER_MODEL_META_PATH=
QC_SUITE_DEVICE=auto
QC_SUITE_CUDA_DEVICE_ID=0
QC_SUITE_STICKER_OCR_MODE=legacy
QC_SUITE_STICKER_OCR_REQUIRED=0
QC_SUITE_STICKER_OCR_FAIL_FAST=0
QC_SUITE_OCR_ENGINE=disabled
QC_SUITE_OCR_MIN_CONFIDENCE=0.70

# Part-ready, clamp, and final decision timing
QC_SUITE_PART_READY_SETTLE_MS=300
QC_SUITE_PART_READY_RELEASE_MS=300
QC_SUITE_PLC_CLAMP_FEEDBACK_FALLBACK_DELAY_MS=100
QC_SUITE_PHASE_STICKER_INSTALL_DELAY_MS=500
QC_SUITE_PHASE_NEXT_PART_DELAY_MS=2000
QC_SUITE_INSPECT_HARD_REJECT_REASONS=OUT_OF_ANGLE,WRONG_TYPE
# Safety-net timeout (ms): if part is settled but no ACCEPT-commit happens within
# this window, commit a COMMIT_TIMEOUT reject + reclamp. 0 = disabled (infer forever).
QC_SUITE_REJECT_TIMEOUT_MS=15000
QC_SUITE_STICKER_COMMIT_GRACE_MS=500
QC_SUITE_ACCEPT_STABLE_FRAMES=2
QC_SUITE_ACCEPT_STABLE_MS=100
QC_SUITE_HARD_REJECT_STABLE_FRAMES=3
QC_SUITE_HARD_REJECT_STABLE_MS=300

# Local PLC / Modbus control
# Keep disabled and dry-run until real hardware or a Modbus simulator is ready.
QC_SUITE_PLC_ENABLED=0
QC_SUITE_PLC_DRY_RUN=1
QC_SUITE_PLC_TRANSPORT=tcp
QC_SUITE_PLC_HOST=127.0.0.1
QC_SUITE_PLC_PORT=5020
QC_SUITE_PLC_SERIAL_PORT=COM3
QC_SUITE_PLC_SERIAL_BAUDRATE=9600
QC_SUITE_PLC_SERIAL_PARITY=N
QC_SUITE_PLC_SERIAL_BYTESIZE=8
QC_SUITE_PLC_SERIAL_STOPBITS=1
QC_SUITE_PLC_TIMEOUT_MS=1000
QC_SUITE_PLC_CLAMP_HOLD_MS=2000
QC_SUITE_PLC_MODBUS_UNIT_ID=1
QC_SUITE_PLC_MODBUS_COMMAND_MODE=coil
QC_SUITE_PLC_MODBUS_HOLD_ADDRESS=0
QC_SUITE_PLC_MODBUS_RELEASE_ADDRESS=0
QC_SUITE_PLC_MODBUS_HOLD_VALUE=1
QC_SUITE_PLC_MODBUS_RELEASE_VALUE=0
QC_SUITE_PLC_MODBUS_ZERO_BASED_ADDRESSING=1
QC_SUITE_PLC_RELAY_CLAMP_ADDRESS=0
QC_SUITE_PLC_RELAY_BUZZER_GREEN_ADDRESS=1
QC_SUITE_PLC_RELAY_RED_ADDRESS=2
QC_SUITE_PLC_RELAY_BUZZER_REJECT_ADDRESS=3
QC_SUITE_PLC_INPUT_RELEASE_ADDRESS=0
QC_SUITE_PLC_INPUT_TEMPLATE_ADDRESS=1
QC_SUITE_PLC_CLAMP_FEEDBACK_ENABLED=0
QC_SUITE_PLC_INPUT_CLAMP_ENGAGED_ADDRESS=2
QC_SUITE_PLC_CLAMP_FEEDBACK_TIMEOUT_MS=1500

# Local training knobs used by the engineer workflow
QC_SUITE_TRAINING_ENGINE_MODE=real
QC_SUITE_TRAINING_TIMEOUT_MINUTES=720
QC_SUITE_TRAINING_DEFAULT_EPOCHS=200
QC_SUITE_TRAINING_DEFAULT_IMGSZ=640
QC_SUITE_TRAINING_DEFAULT_BATCH=16
QC_SUITE_TRAINING_DEFAULT_PATIENCE=20
QC_SUITE_TRAINING_WEIGHTS_DOWNLOAD_ALLOWED=1
QC_SUITE_GPU_FAIL_FAST=1
QC_SUITE_GEOMETRIC_AUGMENT_ENABLED=0

POSTGRESQL_HOST=127.0.0.1
POSTGRESQL_PORT=5432
POSTGRESQL_DATABASE=askiflow_db
POSTGRESQL_USERNAME=
POSTGRESQL_PASSWORD=
POSTGRESQL_SCHEMA=public
POSTGRESQL_SSLMODE=prefer